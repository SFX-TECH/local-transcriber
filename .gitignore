# Python virtual environment
.venv/
venv/
env/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# App runtime data (all local, never committed)
output/
uploads/

# Model caches (Whisper / HuggingFace / CTranslate2)
models/
model-cache/
.cache/
*.bin

# OS / editor noise
Thumbs.db
.DS_Store
desktop.ini
*.swp
.idea/
.vscode/

# Logs
*.log

# Local agent/editor tooling configs (Cline / Roo modes)
.clinerules-*

# Browser-automation artifacts (verification screenshots, traces).
# Only root-level pngs are ignored; committed UI assets live under assets/.
.playwright-mcp/
/*.png
